<view class="page" wx:if="{{loading}}">
  <view class="blob-container">
    <view class="blob blob-blue animate-float" style="top:5%;right:-20%;width:400rpx;height:400rpx"></view>
    <view class="blob blob-purple animate-float-slow" style="bottom:20%;left:-15%;width:350rpx;height:350rpx"></view>
  </view>
  <view class="page-content">
    <view class="glass-card"><text class="loading-text">加载中...</text></view>
  </view>
  <bottom-tab activeTab="" />
</view>

<view class="page" wx:elif="{{error}}">
  <view class="blob-container">
    <view class="blob blob-blue animate-float" style="top:5%;right:-20%;width:400rpx;height:400rpx"></view>
    <view class="blob blob-purple animate-float-slow" style="bottom:20%;left:-15%;width:350rpx;height:350rpx"></view>
  </view>
  <view class="page-content">
    <view class="glass-card error-card">
      <text class="error-text">{{error}}</text>
    </view>
    <view class="btn-w"><button class="btn-p btn-out" bindtap="goHome">返回首页</button></view>
  </view>
  <bottom-tab activeTab="" />
</view>

<view class="page" wx:elif="{{data}}">
  <view class="blob-container">
    <view class="blob blob-blue animate-float" style="top:5%;right:-20%;width:400rpx;height:400rpx"></view>
    <view class="blob blob-purple animate-float-slow" style="bottom:20%;left:-15%;width:350rpx;height:350rpx"></view>
  </view>
  <view class="page-content">
    <summary-card report="{{data.report}}" idea="{{data.idea}}" />
    <view class="btn-w"><button class="btn-p btn-fill" bindtap="goHome">用芥子验证你的想法</button></view>
    <view class="footer-note">AI 分析结果仅供参考，建议结合实地调研综合判断</view>
  </view>
  <bottom-tab activeTab="" />
</view>
