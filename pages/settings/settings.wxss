.page {
  height: 100vh;
  background: transparent;
  position: relative;
  padding-bottom: 48rpx;
}

.page-content {
  position: relative;
  z-index: 1;
}

/* ── User Area ── */
.user-area {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 8rpx 32rpx;
  padding: 40rpx 48rpx;
}

.user-l {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5B6FE6, #8B6FE8);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  border: 4rpx solid rgba(255,255,255,0.4);
  flex-shrink: 0;
}

.uname {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.uid {
  font-size: 22rpx;
  color: #9D9DB0;
  display: block;
  margin-top: 4rpx;
}

.u-icons {
  display: flex;
  gap: 20rpx;
}

.u-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(91,111,230,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

/* ── Stats-2 ── */
.stats-2 {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx;
  margin-top: 16rpx;
}

.stat-2 {
  flex: 1;
  margin: 0;
  text-align: center;
  padding: 36rpx 24rpx;
}

.stat-2 .sw {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin: 0 auto 12rpx;
}

.stat-2 .sv {
  font-size: 44rpx;
  font-weight: 800;
  color: #1a1a2e;
}

.stat-2 .sl {
  font-size: 22rpx;
  color: #9D9DB0;
  display: block;
  margin-top: 4rpx;
}

/* ── Section Label ── */
.sec-lbl {
  font-size: 26rpx;
  font-weight: 600;
  color: #9D9DB0;
  padding: 48rpx 40rpx 20rpx;
  display: block;
}

/* ── Feature Scroll ── */
.feat-scroll {
  display: flex;
  gap: 32rpx;
  padding: 0 32rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.feat-scroll::-webkit-scrollbar {
  display: none;
}

.feat-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  min-width: 144rpx;
  flex-shrink: 0;
}

.feat-item:active {
  opacity: 0.7;
}

.feat-btn-share {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  min-width: 144rpx;
  flex-shrink: 0;
  border: none;
  background: none;
  padding: 0;
  font-family: inherit;
  line-height: inherit;
}

.feat-btn-share::after {
  display: none;
}

.feat-btn-share:active {
  opacity: 0.7;
}

.feat-av {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #fff;
}

.gradient-primary {
  background: linear-gradient(135deg, #5B6FE6, #8B6FE8);
}

.feat-n {
  font-size: 22rpx;
  color: #6B6B80;
  white-space: nowrap;
}

/* ── Menu Q ── */
.menu-q {
  margin: 0 32rpx;
  padding: 8rpx 32rpx;
}

.menu-q-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 8rpx;
  border-bottom: 2rpx solid rgba(200,196,216,0.15);
}

.menu-q-item:last-child {
  border-bottom: none;
}

.menu-q-item:active {
  opacity: 0.7;
}

.menu-q-l {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-q-i {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(91,111,230,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.menu-q-t {
  font-size: 28rpx;
  color: #1a1a2e;
}

.menu-q-ar {
  color: #C8C8D8;
  font-size: 32rpx;
}

/* ── History List ── */
.history-list {
  padding: 0 32rpx;
}

.time-group {
  margin-bottom: 24rpx;
}

.time-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #9D9DB0;
  display: block;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin: 0 0 8rpx;
  padding: 24rpx 28rpx;
}

.history-item:active {
  opacity: 0.8;
}

.hi-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.hi-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.verdict-pass { background: #34C472; }
.verdict-fail { background: #FF6B6B; }
.verdict-neutral { background: #9D9DB0; }

.hi-title {
  font-size: 26rpx;
  color: #1a1a2e;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.hi-time {
  font-size: 22rpx;
  color: #9D9DB0;
  flex-shrink: 0;
}

/* ── Empty State ── */
.empty-hint {
  text-align: center;
  font-size: 26rpx;
  color: #9D9DB0;
  padding: 40rpx;
  margin: 0 32rpx;
}
