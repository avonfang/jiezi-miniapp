.page {
  height: 100vh;
  padding-bottom: 48rpx;
  background: transparent;
  position: relative;
}

.page-content {
  position: relative;
  z-index: 1;
  padding-bottom: 180rpx;
}

/* ── Verdict Banner ── */
.verdict-banner {
  margin: 24rpx;
  padding: 48rpx 40rpx;
  border-radius: 32rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.verdict-banner.verdict-try {
  background: linear-gradient(135deg, #34C472, #56D98A);
  color: #fff;
}

.verdict-banner.verdict-explore {
  background: linear-gradient(135deg, #F59E6B, #F7B84D);
  color: #fff;
}

.verdict-banner.verdict-no {
  background: linear-gradient(135deg, #F56B6B, #F78B8B);
  color: #fff;
}

.v-title {
  font-size: 56rpx;
  font-weight: 800;
  display: block;
  text-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.v-reason {
  font-size: 26rpx;
  opacity: 0.9;
  display: block;
  margin-top: 12rpx;
  line-height: 1.6;
}

/* ── Glass Card ── */
.glass-card {
  margin: 16rpx 24rpx;
  border-radius: 32rpx;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 8rpx 40rpx rgba(91, 111, 230, 0.08);
}

/* ── Summary Grid ── */
.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.summary-item {
  text-align: center;
  padding: 28rpx 16rpx;
  border-radius: 24rpx;
}

.summary-icon {
  font-size: 40rpx;
  display: block;
  margin-bottom: 4rpx;
}

.summary-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #5B6FE6;
  display: block;
}

.summary-label {
  font-size: 22rpx;
  color: #9D9DB0;
  display: block;
  margin-top: 2rpx;
}

/* ── Section Head ── */
.section-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 28rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
}

/* ── Scores (s-row) ── */
.s-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.s-row:last-child {
  margin-bottom: 0;
}

.s-lbl {
  width: 160rpx;
  font-size: 24rpx;
  flex-shrink: 0;
  color: #6B6B80;
}

.s-bar-bg {
  flex: 1;
  height: 16rpx;
  background: rgba(200,196,216,0.25);
  border-radius: 999px;
  overflow: hidden;
}

.s-bar-fill {
  height: 100%;
  border-radius: 999px;
  background: linear-gradient(135deg, #5B6FE6, #8B6FE8);
}

.s-bar-fill.green {
  background: linear-gradient(135deg, #34C472, #56D98A);
}

.s-num {
  font-size: 28rpx;
  font-weight: 700;
  width: 60rpx;
  text-align: right;
  color: #1a1a2e;
}

/* ── Sub-scores (d-row) ── */
.d-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid rgba(200,196,216,0.15);
}

.d-row:last-child {
  border-bottom: none;
}

.d-lbl {
  font-size: 26rpx;
  color: #1a1a2e;
  flex-shrink: 0;
}

.d-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.dots {
  display: flex;
  gap: 10rpx;
}

.dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: rgba(200, 196, 216, 0.15);
  border: 2rpx solid rgba(200, 196, 216, 0.15);
  transition: all 0.3s ease;
}

/* Filled dot: translucent glass colors by score tier */
.dot.on {
  border-color: transparent;
}

.dot.on-high {
  background: linear-gradient(135deg, rgba(52, 196, 114, 0.75), rgba(86, 217, 138, 0.55));
  box-shadow: 0 2rpx 10rpx rgba(52, 196, 114, 0.25);
}

.dot.on-mid {
  background: linear-gradient(135deg, rgba(245, 166, 35, 0.75), rgba(247, 217, 77, 0.55));
  box-shadow: 0 2rpx 10rpx rgba(245, 166, 35, 0.25);
}

.dot.on-low {
  background: linear-gradient(135deg, rgba(245, 107, 107, 0.75), rgba(247, 139, 139, 0.55));
  box-shadow: 0 2rpx 10rpx rgba(245, 107, 107, 0.25);
}

.d-num {
  font-size: 24rpx;
  font-weight: 700;
  min-width: 48rpx;
  text-align: right;
  transition: color 0.3s ease;
}

.d-num-high { color: #34C472; }
.d-num-mid  { color: #D4A017; }
.d-num-low  { color: #F56B6B; }

/* ── Competitors ── */
.comp-item {
  padding: 24rpx 0;
  border-bottom: 2rpx solid rgba(200,196,216,0.15);
}

.comp-item:last-child {
  border-bottom: none;
}

.comp-name {
  font-size: 26rpx;
  font-weight: 600;
  display: block;
}

.comp-desc {
  font-size: 24rpx;
  color: #6B6B80;
  display: block;
  margin-top: 4rpx;
}

/* ── SWOT ── */
.swot {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.swot-cell {
  padding: 28rpx;
  border-radius: 20rpx;
}

.swot-s { background: rgba(52,196,114,0.08); }
.swot-w { background: rgba(245,107,107,0.08); }
.swot-o { background: rgba(91,111,230,0.06); }
.swot-t { background: rgba(245,158,107,0.08); }

.swot-lbl {
  font-size: 26rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
}

.swot-item {
  font-size: 24rpx;
  display: block;
  padding: 4rpx 0;
  color: #6B6B80;
  line-height: 1.5;
}

/* ── Risk ── */
.risk-card {
  border-left: 10rpx solid #F56B6B;
}

.risk-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #F56B6B;
}

.risk-item {
  display: flex;
  gap: 16rpx;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #6B6B80;
  line-height: 1.5;
}

.risk-bullet {
  color: #F56B6B;
  flex-shrink: 0;
}

/* ── Body Text ── */
.body-text {
  font-size: 26rpx;
  line-height: 1.7;
  color: #6B6B80;
  display: block;
  word-break: break-word;
  overflow-wrap: break-word;
}

