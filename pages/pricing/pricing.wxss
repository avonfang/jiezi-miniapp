.page {
  height: 100vh;
  background: transparent;
  position: relative;
  padding-bottom: 48rpx;
}

.page-content {
  position: relative;
  z-index: 1;
  padding-bottom: 48rpx;
}

/* ── Balance Area ── */
.balance-area {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 12rpx;
  padding: 56rpx 40rpx 0;
}

.b-label {
  font-size: 28rpx;
  color: #6B6B80;
}

.b-count {
  font-size: 88rpx;
  font-weight: 800;
  color: #1a1a2e;
  letter-spacing: -2rpx;
}

.b-unit {
  font-size: 28rpx;
  color: #6B6B80;
}

/* ── Plan Header ── */
.plan-h {
  padding: 48rpx 40rpx 24rpx;
}

.plan-h-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

/* ── Plan Card ── */
.plan-c {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 40rpx 48rpx;
  margin: 0 32rpx 20rpx;
  position: relative;
  transition: all 0.2s;
}

.plan-c:active {
  opacity: 0.85;
}

.plan-c.sel {
  border-color: #5B6FE6;
  background: linear-gradient(135deg, rgba(255,255,255,0.9), rgba(91,111,230,0.06));
  box-shadow: 0 8rpx 32rpx rgba(91,111,230,0.12);
}

.plan-badge {
  position: absolute;
  top: -20rpx;
  right: 40rpx;
  background: linear-gradient(135deg, #F59E6B, #F7B84D);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 28rpx;
  border-radius: 999px;
  box-shadow: 0 4rpx 16rpx rgba(245,158,107,0.35);
}

.plan-info {
  flex: 1;
}

.plan-n {
  font-size: 32rpx;
  font-weight: 700;
  display: block;
  color: #1a1a2e;
}

.plan-cr {
  font-size: 24rpx;
  color: #9D9DB0;
  display: block;
  margin-top: 4rpx;
}

.plan-pr-area {
  text-align: right;
}

.plan-pr {
  font-size: 40rpx;
  font-weight: 800;
  color: #F56B6B;
  display: block;
}

.plan-pp {
  font-size: 20rpx;
  color: #9D9DB0;
  display: block;
  margin-top: 2rpx;
}

.plan-chk {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid #E0E0EC;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.plan-chk.on {
  background: linear-gradient(135deg, #5B6FE6, #8B6FE8);
  border-color: transparent;
}

.plan-chk.on .chk {
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

/* ── Top-up Row ── */
.topup-row {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx;
}

.topup-c {
  flex: 1;
  padding: 36rpx;
  text-align: center;
  transition: all 0.2s;
}

.topup-c:active {
  opacity: 0.85;
}

.topup-c.sel {
  border-color: #5B6FE6;
  background: linear-gradient(135deg, rgba(255,255,255,0.9), rgba(91,111,230,0.06));
  box-shadow: 0 8rpx 24rpx rgba(91,111,230,0.1);
}

.topup-n {
  font-size: 26rpx;
  font-weight: 600;
  display: block;
}

.topup-cr {
  font-size: 40rpx;
  font-weight: 800;
  color: #5B6FE6;
  display: block;
  margin: 12rpx 0;
}

.topup-pr {
  font-size: 28rpx;
  color: #F56B6B;
  font-weight: 600;
  display: block;
}

/* ── Pay Area ── */
.pay-w {
  padding: 40rpx 32rpx 0;
  opacity: 0;
  transform: translateY(10rpx);
  transition: all 0.3s;
}

.pay-w.visible {
  opacity: 1;
  transform: translateY(0);
}

.pay-b {
  width: 100%;
  padding: 32rpx;
  border: none;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #5B6FE6, #8B6FE8);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  font-family: inherit;
  box-shadow: 0 8rpx 40rpx rgba(91,111,230,0.3);
  transition: all 0.2s;
}

.pay-b:active {
  transform: scale(0.98);
}

.pay-b[disabled] {
  opacity: 0.5;
  transform: none;
}

/* ── QR ── */
.qr-card {
  text-align: center;
  padding: 48rpx 32rpx;
}

.qr-title {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 24rpx;
  color: #1a1a2e;
}

.qr-image {
  width: 400rpx;
  height: 400rpx;
  display: block;
  margin: 0 auto;
  border-radius: 16rpx;
}

.qr-hint {
  font-size: 24rpx;
  color: #9D9DB0;
  display: block;
  margin-top: 20rpx;
}

/* ── Success ── */
.success-card {
  text-align: center;
  padding: 64rpx 32rpx;
}

.success-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #34C472, #56D98A);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(52,196,114,0.3);
}

.success-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: 700;
}

.success-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  color: #1a1a2e;
}

.success-detail {
  font-size: 28rpx;
  color: #6B6B80;
  display: block;
  margin-top: 8rpx;
}

