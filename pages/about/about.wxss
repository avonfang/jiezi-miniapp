.page {
  min-height: 100vh;
  background: transparent;
  position: relative;
  padding-bottom: 48rpx;
}

.page-content {
  position: relative;
  z-index: 1;
  padding: 24rpx 32rpx;
}

/* ── Brand ── */
.ab-brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 32rpx;
}

.ab-logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.ab-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.ab-version {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
}

.ab-tagline {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 12rpx;
  text-align: center;
}

/* ── Section ── */
.ab-section {
  margin-bottom: 32rpx;
}

.ab-section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-muted);
  display: block;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

/* ── Feature Card ── */
.ab-card {
  display: flex;
  gap: 20rpx;
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid rgba(255,255,255,0.4);
  box-shadow: var(--shadow-glass);
}

.ab-card-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ab-card-icon {
  font-size: 32rpx;
}

.ab-card-body {
  flex: 1;
  min-width: 0;
}

.ab-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
}

.ab-card-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  display: block;
  margin-top: 6rpx;
}

/* ── Links ── */
.ab-link {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  border-radius: var(--radius-sm);
  padding: 24rpx 28rpx;
  margin-bottom: 8rpx;
  border: 1rpx solid rgba(255,255,255,0.4);
  box-shadow: var(--shadow-glass);
}

.ab-link:active {
  opacity: 0.7;
}

.ab-link-label {
  font-size: 26rpx;
  color: var(--color-text);
  font-weight: 500;
}

.ab-link-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.ab-link-url {
  font-size: 24rpx;
  color: var(--color-primary);
}

/* ── Legal ── */
.ab-legal {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  padding: 40rpx 0 12rpx;
}

.ab-legal-text {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.ab-legal-text:active {
  color: var(--color-primary);
}

.ab-legal-divider {
  font-size: 22rpx;
  color: var(--color-border);
}

/* ── Copyright ── */
.ab-copyright {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: var(--color-text-muted);
  padding-bottom: 48rpx;
}
